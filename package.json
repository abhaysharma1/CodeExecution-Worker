{
  "name": "code-execution-worker",
  "version": "1.0.0",
  "private": true,
  "description": "Production-ready SQS worker for code execution",
  "main": "dist/worker.js",
  "scripts": {
    "dev": "tsx watch src/worker.ts",
    "dev:api": "tsx watch src/test-api.ts",
    "build": "prisma generate && tsc -p tsconfig.json",
    "start": "node dist/worker.js",
    "start:api": "node dist/test-api.js",
    "prisma:generate": "prisma generate"
  },
  "dependencies": {
    "@aws-sdk/client-sqs": "^3.883.0",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "axios": "^1.7.9",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "morgan": "^1.10.0",
    "pg": "^8.20.0",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.10.2",
    "prisma": "^7.6.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
