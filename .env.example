AWS_REGION=us-east-1

# Database
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/codecoliseum?schema=express

# Piston
PISTON_URL=http://piston:2000

# SQS (LocalStack)
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
SQS_ENDPOINT=http://localstack:4566
EXAM_SQS_QUEUE_URL=http://localstack:4566/000000000000/codecoliseum-exam
PRACTICE_SQS_QUEUE_URL=http://localstack:4566/000000000000/codecoliseum-practice

# Optional
PORT=3000
SQS_WAIT_TIME_SECONDS=20
WORKER_IDLE_SLEEP_MS=2000
